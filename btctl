#!/usr/bin/env bash
set -euo pipefail

# This public dispatcher keeps the normal Python path fast while allowing a
# stock Unraid host to run the same CLI through a short-lived local image.

EX_USAGE=64
EX_NOPERM=77
SCRIPT_DIR="$(CDPATH= cd -P -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
DOCKER_BIN="${BTCTL_DOCKER_BIN:-docker}"
HOST_LOCK_DIRECTORY=/run/cwa-translate-btctl-locks

fail() {
    local status="$1"
    shift
    printf 'btctl: %s\n' "$*" >&2
    exit "$status"
}

native_tools_are_compatible() {
    command -v python3 >/dev/null 2>&1 \
        && python3 -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 11) else 1)' \
            >/dev/null 2>&1 \
        && command -v git >/dev/null 2>&1 \
        && git --version >/dev/null 2>&1
}

if [ "${BTCTL_FORCE_CONTAINER:-0}" != "1" ] && native_tools_are_compatible; then
    unset BTCTL_EXPECTED_REVISION BTCTL_OPERATOR_REVISION BTCTL_LOCK_DIRECTORY
    exec python3 "$SCRIPT_DIR/btctl.py" "$@"
fi

if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    fail "$EX_NOPERM" \
        "the containerized Unraid path must run as root (compatible host Python 3.11+ and Git were not both available)"
fi
command -v "$DOCKER_BIN" >/dev/null 2>&1 \
    || fail 1 "Docker is required for the stock-Unraid bootstrap"
[ -S /var/run/docker.sock ] \
    || fail 1 "the local Docker socket /var/run/docker.sock is unavailable"
unset DOCKER_CONTEXT DOCKER_TLS_VERIFY DOCKER_CERT_PATH
export DOCKER_HOST=unix:///var/run/docker.sock
"$DOCKER_BIN" version --format '{{.Server.Version}}' >/dev/null 2>&1 \
    || fail 1 "the Docker daemon is unavailable"

repository="$SCRIPT_DIR"
repository_argument=0
env_file=""
command=""
help_requested=0
arguments=("$@")

for ((index = 0; index < ${#arguments[@]}; index += 1)); do
    argument="${arguments[$index]}"
    case "$argument" in
        --repository)
            ((index += 1))
            [ "$index" -lt "${#arguments[@]}" ] \
                || fail "$EX_USAGE" "--repository requires one path"
            repository="${arguments[$index]}"
            repository_argument=1
            ;;
        --repository=*)
            repository="${argument#--repository=}"
            repository_argument=1
            ;;
        --env)
            ((index += 1))
            [ "$index" -lt "${#arguments[@]}" ] \
                || fail "$EX_USAGE" "--env requires one path"
            env_file="${arguments[$index]}"
            ;;
        --env=*)
            env_file="${argument#--env=}"
            ;;
        plan|install|adopt|auth-snippet|doctor|uninstall|upgrade|rollback)
            if [ -z "$command" ]; then
                command="$argument"
            fi
            ;;
        -h|--help)
            help_requested=1
            ;;
    esac
done

operator_arguments=("${arguments[@]}")
if [ "$repository_argument" -eq 0 ]; then
    operator_arguments=(--repository "$SCRIPT_DIR" "${operator_arguments[@]}")
fi

canonical_existing_file() {
    local candidate="$1"
    local label="$2"
    local parent base canonical
    [ "${candidate#/}" != "$candidate" ] \
        || fail "$EX_USAGE" "$label must be an absolute path"
    [ ! -L "$candidate" ] && [ -f "$candidate" ] \
        || fail "$EX_USAGE" "$label must be one real regular file"
    parent="$(CDPATH= cd -P -- "$(dirname -- "$candidate")" && pwd -P)" \
        || fail "$EX_USAGE" "$label parent could not be resolved"
    base="$(basename -- "$candidate")"
    canonical="$parent/$base"
    [ "$canonical" = "$candidate" ] \
        || fail "$EX_USAGE" "$label must use one canonical path without symbolic components"
    case "$canonical" in
        *','*|*$'\n'*|*$'\r'*|*$'\t'*)
            fail "$EX_USAGE" "$label contains a character unsupported by Docker --mount"
            ;;
    esac
    printf '%s\n' "$canonical"
}

prepare_host_lock_directory() {
    if [ ! -e "$HOST_LOCK_DIRECTORY" ]; then
        if ! mkdir -m 0700 -- "$HOST_LOCK_DIRECTORY" 2>/dev/null \
            && [ ! -d "$HOST_LOCK_DIRECTORY" ]; then
            fail 1 "the Unraid lifecycle lock directory could not be created"
        fi
    fi
    [ -d "$HOST_LOCK_DIRECTORY" ] && [ ! -L "$HOST_LOCK_DIRECTORY" ] \
        || fail 1 "the Unraid lifecycle lock directory must be one real directory"
    [ "$(stat -c '%u:%a' -- "$HOST_LOCK_DIRECTORY")" = "0:700" ] \
        || fail 1 "the Unraid lifecycle lock directory must be root-owned mode 0700"
}

source_exporter_dockerfile() {
    printf '%s\n' \
        'FROM python:3.11-alpine@sha256:25976e9d34a0fab1f278cae931f34c8303d97bf0c0d7f85b6b4dcf641d7702a4 AS source-exporter' \
        'RUN apk add --no-cache \' \
        '    brotli-libs=1.2.0-r1 \' \
        '    c-ares=1.34.8-r0 \' \
        '    git=2.54.0-r0 \' \
        '    git-init-template=2.54.0-r0 \' \
        '    libcurl=8.21.0-r0 \' \
        '    libexpat=2.8.2-r0 \' \
        '    libidn2=2.3.8-r0 \' \
        '    libpsl=0.21.5-r3 \' \
        '    libunistring=1.4.2-r0 \' \
        '    nghttp2-libs=1.69.0-r0 \' \
        '    pcre2=10.47-r1 \' \
        '    zstd-libs=1.5.7-r2'
}

[ "$repository" = "$SCRIPT_DIR" ] \
    || fail "$EX_USAGE" \
        "the stock-Unraid fallback requires --repository to be this btctl checkout"
[ -d "$SCRIPT_DIR/.git" ] && [ ! -L "$SCRIPT_DIR/.git" ] \
    || fail "$EX_USAGE" "the stock-Unraid fallback requires a full Git checkout"
case "$SCRIPT_DIR" in
    *','*|*$'\n'*|*$'\r'*|*$'\t'*)
        fail "$EX_USAGE" "repository path contains a character unsupported by Docker --mount"
        ;;
esac

if [ -n "$env_file" ]; then
    env_file="$(canonical_existing_file "$env_file" "environment file")"
fi

case "$command" in
    install|adopt|doctor|uninstall|upgrade|rollback)
        prepare_host_lock_directory
        ;;
esac

temporary="$(mktemp -d "${TMPDIR:-/tmp}/btctl-bootstrap.XXXXXX")" \
    || fail 1 "could not create a private bootstrap directory"
chmod 700 "$temporary"
exporter_image=""
operator_image=""
bootstrap_tag="${temporary##*.}"
exporter_ref="local/cwa-translate-btctl-exporter:bootstrap-${bootstrap_tag}"
operator_ref="local/cwa-translate-btctl-operator:bootstrap-${bootstrap_tag}"
exporter_tagged=0
operator_tagged=0

cleanup() {
    local status=$?
    trap - EXIT HUP INT TERM
    if [ "$operator_tagged" -eq 1 ]; then
        "$DOCKER_BIN" image rm "$operator_ref" >/dev/null 2>&1 || true
    fi
    if [ "$exporter_tagged" -eq 1 ]; then
        "$DOCKER_BIN" image rm "$exporter_ref" >/dev/null 2>&1 || true
    fi
    rm -rf -- "$temporary"
    exit "$status"
}
trap cleanup EXIT HUP INT TERM

printf 'btctl: preparing the local stock-Unraid operator image\n' >&2
source_exporter_dockerfile | "$DOCKER_BIN" build \
    --pull=false \
    --target source-exporter \
    --tag "$exporter_ref" \
    --iidfile "$temporary/exporter.iid" \
    --file - \
    "$temporary" >&2 \
    || fail 1 "source exporter image could not be built"
exporter_tagged=1
exporter_image="$(<"$temporary/exporter.iid")"
[[ "$exporter_image" =~ ^sha256:[0-9a-f]{64}$ ]] \
    || fail 1 "Docker returned an invalid source exporter image ID"
[ "$("$DOCKER_BIN" image inspect --format '{{.Id}}' "$exporter_ref")" = "$exporter_image" ] \
    || fail 1 "source exporter tag does not resolve to the built image"

git_environment=(
    --env GIT_NO_REPLACE_OBJECTS=1
    --env GIT_OPTIONAL_LOCKS=0
    --env GIT_CONFIG_NOSYSTEM=1
    --env GIT_CONFIG_GLOBAL=/dev/null
    --env GIT_CONFIG_COUNT=3
    --env GIT_CONFIG_KEY_0=safe.directory
    --env "GIT_CONFIG_VALUE_0=$SCRIPT_DIR"
    --env GIT_CONFIG_KEY_1=core.fsmonitor
    --env GIT_CONFIG_VALUE_1=false
    --env GIT_CONFIG_KEY_2=core.untrackedCache
    --env GIT_CONFIG_VALUE_2=false
)
readonly_runtime=(
    --rm
    --user 0:0
    --network none
    --read-only
    --pids-limit 64
    --cap-drop ALL
    --cap-add DAC_READ_SEARCH
    --security-opt no-new-privileges:true
    --tmpfs /tmp:rw,nosuid,nodev,noexec,size=16m
)
repository_mount=(
    --mount "type=bind,src=$SCRIPT_DIR,dst=$SCRIPT_DIR,readonly"
)

"$DOCKER_BIN" run \
    "${readonly_runtime[@]}" \
    "${git_environment[@]}" \
    "${repository_mount[@]}" \
    "$exporter_image" \
    /bin/sh -ec '
        repository="$1"
        top="$(git -C "$repository" rev-parse --show-toplevel)"
        test "$top" = "$repository"
        git -C "$repository" ls-files --error-unmatch VERSION >/dev/null
        test ! -L "$repository/VERSION"
        revision="$(git -C "$repository" rev-parse HEAD)"
        test -z "$(git -C "$repository" status --porcelain=v1 --untracked-files=all)"
        version="$(tr -d "\r\n" < "$repository/VERSION")"
        python3 -c '\''import re,sys; valid_revision=re.fullmatch(r"[0-9a-f]{40}",sys.argv[1]); valid_version=re.fullmatch(r"(?:0|[1-9][0-9]*)\.(?:0|[1-9][0-9]*)\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\.[0-9A-Za-z-]+)*)?",sys.argv[2]); raise SystemExit(0 if valid_revision and valid_version else 65)'\'' "$revision" "$version"
        printf "%s\n%s\n" "$revision" "$version"
    ' sh "$SCRIPT_DIR" >"$temporary/identity" \
    || fail "$EX_USAGE" "installation requires one exact clean Git checkout"

mapfile -t identity <"$temporary/identity"
[ "${#identity[@]}" -eq 2 ] \
    || fail 1 "source exporter returned an invalid identity"
revision="${identity[0]}"
version="${identity[1]}"
[[ "$revision" =~ ^[0-9a-f]{40}$ ]] \
    || fail 1 "source exporter returned an invalid revision"

"$DOCKER_BIN" run \
    "${readonly_runtime[@]}" \
    "${git_environment[@]}" \
    "${repository_mount[@]}" \
    "$exporter_image" \
    /bin/sh -ec '
        repository="$1"
        expected="$2"
        test "$(git -C "$repository" rev-parse HEAD)" = "$expected"
        test -z "$(git -C "$repository" status --porcelain=v1 --untracked-files=all)"
        exec git -C "$repository" archive --format=tar "$expected"
    ' sh "$SCRIPT_DIR" "$revision" \
| "$DOCKER_BIN" build \
    --pull=false \
    --target operator \
    --build-arg "BTCTL_SOURCE_REVISION=$revision" \
    --build-arg "BTCTL_SOURCE_VERSION=$version" \
    --label "io.cwa-translate.btctl.revision=$revision" \
    --label "io.cwa-translate.btctl.version=$version" \
    --tag "$operator_ref" \
    --iidfile "$temporary/operator.iid" \
    --file Dockerfile.btctl \
    - >&2 \
    || fail 1 "verified operator image could not be built"
operator_tagged=1
operator_image="$(<"$temporary/operator.iid")"
[[ "$operator_image" =~ ^sha256:[0-9a-f]{64}$ ]] \
    || fail 1 "Docker returned an invalid operator image ID"
[ "$("$DOCKER_BIN" image inspect --format '{{.Id}}' "$operator_ref")" = "$operator_image" ] \
    || fail 1 "operator tag does not resolve to the built image"

operator_revision="$(
    "$DOCKER_BIN" image inspect \
        --format '{{index .Config.Labels "io.cwa-translate.btctl.revision"}}' \
        "$operator_image"
)" || fail 1 "operator image identity could not be inspected"
[ "$operator_revision" = "$revision" ] \
    || fail 1 "operator image revision does not match the verified checkout"

operator_environment=(
    --env HOME=/tmp/home
    --env DOCKER_CONFIG=/tmp/docker
    --env PYTHONDONTWRITEBYTECODE=1
    --env "BTCTL_EXPECTED_REVISION=$revision"
    "${git_environment[@]}"
)

run_operator_without_plan() {
    "$DOCKER_BIN" run \
        "${readonly_runtime[@]}" \
        "${operator_environment[@]}" \
        "${repository_mount[@]}" \
        "$operator_image" \
        "$@"
}

if [ "$help_requested" -eq 1 ] || [ -z "$command" ] || [ -z "$env_file" ]; then
    run_operator_without_plan "${operator_arguments[@]}"
    exit $?
fi

planner_mounts=("${repository_mount[@]}")
planner_mounts+=(--mount "type=bind,src=$env_file,dst=$env_file,readonly")
if [ -d /mnt ]; then
    planner_mounts+=(--mount type=bind,src=/mnt,dst=/mnt,readonly)
fi
if [ -d /boot ]; then
    planner_mounts+=(--mount type=bind,src=/boot,dst=/boot,readonly)
fi

"$DOCKER_BIN" run \
    "${readonly_runtime[@]}" \
    "${operator_environment[@]}" \
    "${planner_mounts[@]}" \
    --entrypoint python3 \
    "$operator_image" \
    /opt/btctl/btctl_container.py \
    --repository "$SCRIPT_DIR" \
    --env "$env_file" \
    --command "$command" \
    --expected-revision "$revision" >"$temporary/mount-plan" \
    || fail "$EX_USAGE" "the Unraid mount plan was rejected"

final_mounts=()
socket_required=0
socket_records=0
lock_records=0
line_number=0
validate_planned_path() {
    local candidate="$1"
    [ "${candidate#/}" != "$candidate" ] && [ "$candidate" != "/" ] \
        || fail 1 "mount planner emitted a non-absolute path"
    case "$candidate" in
        *','*|*$'\n'*|*$'\r'*|*$'\t'*)
            fail 1 "mount planner emitted an unsafe Docker mount path"
            ;;
    esac
}
while IFS=$'\t' read -r record first second fourth; do
    ((line_number += 1))
    if [ "$line_number" -eq 1 ]; then
        [ "$record" = "BTCTL_MOUNT_PLAN" ] \
            && [ "$first" = "1" ] \
            && [ "$second" = "$command" ] \
            && [ "$fourth" = "unraid" ] \
            || fail 1 "mount planner emitted an invalid header"
        continue
    fi
    case "$record:$first" in
        mount:ro)
            [ -z "$fourth" ] || fail 1 "mount planner emitted an invalid mount record"
            [ -n "$second" ] || fail 1 "mount planner emitted an empty path"
            validate_planned_path "$second"
            final_mounts+=(--mount "type=bind,src=$second,dst=$second,readonly")
            ;;
        mount:rw)
            [ -z "$fourth" ] || fail 1 "mount planner emitted an invalid mount record"
            [ -n "$second" ] || fail 1 "mount planner emitted an empty path"
            validate_planned_path "$second"
            final_mounts+=(--mount "type=bind,src=$second,dst=$second")
            ;;
        lock:ro)
            [ -n "$second" ] || fail 1 "mount planner emitted an empty lock source"
            validate_planned_path "$second"
            [ "$second" = "$HOST_LOCK_DIRECTORY" ] \
                || fail 1 "mount planner emitted an invalid lock source"
            [ "$fourth" = "/run/btctl-lock" ] \
                || fail 1 "mount planner emitted an invalid lock destination"
            final_mounts+=(
                --mount "type=bind,src=$second,dst=$fourth,readonly"
            )
            operator_environment+=(--env "BTCTL_LOCK_DIRECTORY=$fourth")
            ((lock_records += 1))
            ;;
        socket:yes)
            [ -z "$fourth" ] || fail 1 "mount planner emitted an invalid socket record"
            [ -z "$second" ] || fail 1 "mount planner emitted an invalid socket record"
            socket_required=1
            ((socket_records += 1))
            ;;
        socket:no)
            [ -z "$fourth" ] || fail 1 "mount planner emitted an invalid socket record"
            [ -z "$second" ] || fail 1 "mount planner emitted an invalid socket record"
            ((socket_records += 1))
            ;;
        *)
            fail 1 "mount planner emitted an unsupported record"
            ;;
    esac
done <"$temporary/mount-plan"
[ "$line_number" -ge 2 ] || fail 1 "mount planner emitted an incomplete plan"
[ "$socket_records" -eq 1 ] || fail 1 "mount planner emitted an invalid socket policy"
case "$command:$socket_required" in
    plan:0|auth-snippet:0|install:1|adopt:1|doctor:1|uninstall:1|upgrade:1|rollback:1) ;;
    *) fail 1 "mount planner emitted an invalid command socket policy" ;;
esac
case "$command:$lock_records" in
    plan:0|auth-snippet:0|install:1|adopt:1|doctor:1|uninstall:1|upgrade:1|rollback:1) ;;
    *) fail 1 "mount planner emitted an invalid lifecycle lock policy" ;;
esac

final_runtime=(
    --rm
    --user 0:0
    --network none
    --read-only
    --pids-limit 128
    --cap-drop ALL
    --cap-add CHOWN
    --cap-add DAC_OVERRIDE
    --cap-add FOWNER
    --cap-add FSETID
    --security-opt no-new-privileges:true
    --tmpfs /tmp:rw,nosuid,nodev,noexec,size=64m
    --tmpfs /run:rw,nosuid,nodev,noexec,size=16m
)
if [ "$socket_required" -eq 1 ]; then
    final_mounts+=(
        --mount type=bind,src=/var/run/docker.sock,dst=/var/run/docker.sock
    )
fi

"$DOCKER_BIN" run \
    "${final_runtime[@]}" \
    "${operator_environment[@]}" \
    "${final_mounts[@]}" \
    "$operator_image" \
    "${operator_arguments[@]}"
