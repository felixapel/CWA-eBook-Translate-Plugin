<?xml version="1.0"?>
<Container version="2">
  <Name>book-translator-api</Name>
  <Repository>local/book-translator-api:latest</Repository>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <ExtraParams>--read-only --tmpfs /tmp:rw,noexec,nosuid,size=64m,uid=101,gid=102,mode=700 --cap-drop=ALL --security-opt=no-new-privileges:true -e BT_ROLE=api</ExtraParams>
  <Overview>Non-root backend API for the Calibre-Web-Automated Book Translator plugin. The private database bind mount must be writable by uid 101 gid 102 and permit mode 0700.</Overview>
  <Category>Tools:Utilities</Category>
  <Config Name="Appdata (Database)" Target="/app/data" Default="/mnt/user/appdata/book-translator-api/data" Mode="rw" Description="Holds translations.db SQLite database" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/book-translator-api/data</Config>
  <Config Name="Port" Target="8390" Default="8390" Mode="tcp" Description="API Port" Type="Port" Display="always" Required="true" Mask="false">8390</Config>
  <Config Name="Auth Mode" Target="BT_AUTH_MODE" Default="cwa_session" Mode="" Description="Authentication authority: cwa_session (safe default with exact CWA URL/origin), token (manual compatibility), or forwarded behind an identity proxy. Never use disabled in production." Type="Variable" Display="always" Required="true" Mask="false">cwa_session</Config>
  <Config Name="API Token" Target="BT_API_TOKEN" Default="" Mode="" Description="Optional operator credential in cwa_session mode. Token browser authentication requires a separately reviewed custom bootstrap because the shared secret is JavaScript-readable." Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="CWA Auth URL" Target="BT_CWA_AUTH_URL" Default="" Mode="" Description="Required when Auth Mode is cwa_session. Full internal URL to CWA's authenticated JSON probe, e.g. http://192.168.1.10:8383/ajax/emailstat." Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="Exact CWA Origin" Target="BT_ALLOWED_ORIGINS" Default="" Mode="" Description="Required for cross-origin cwa_session installs. The supplied direct-port overlay is HTTP-only, e.g. http://192.168.1.10:8383; HTTPS readers need a TLS/same-origin proxy or custom TLS apiUrl. Do not add a path or wildcard." Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="CWA Auth Response Limit" Target="BT_CWA_AUTH_MAX_RESPONSE_BYTES" Default="262144" Mode="" Description="Maximum decompressed bytes accepted from CWA's authenticated JSON probe." Type="Variable" Display="advanced" Required="false" Mask="false">262144</Config>
  <Config Name="Allow Private LAN CORS" Target="BT_ALLOW_PRIVATE_LAN" Default="false" Mode="" Description="Broad private-subnet CORS compatibility for non-cookie modes. cwa_session ignores it and requires the exact origin above." Type="Variable" Display="advanced" Required="false" Mask="false">false</Config>
  <Config Name="LLM Provider" Target="LLM_PROVIDER" Default="local" Mode="" Description="Provider (e.g. local, openai, anthropic, gemini, groq)" Type="Variable" Display="always" Required="false" Mask="false">local</Config>
  <Config Name="LLM Model" Target="LLM_MODEL" Default="gemma4-12b" Mode="" Description="Model name" Type="Variable" Display="always" Required="false" Mask="false">gemma4-12b</Config>
  <Config Name="LLM API Key" Target="LLM_API_KEY" Default="" Mode="" Description="API Key" Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="Local LLM URL" Target="BT_LOCAL_URL" Default="http://192.168.1.10:8000/v1/chat/completions" Mode="" Description="OpenAI-compatible endpoint of your local LLM (only when provider=local). Path is always /v1/chat/completions; set host:port to YOUR server. Ports: vLLM 8000, LM Studio 1234, Ollama 11434. Use the host IP, NOT localhost/127.0.0.1." Type="Variable" Display="always" Required="false" Mask="false">http://192.168.1.10:8000/v1/chat/completions</Config>
  <Config Name="Batch Size" Target="BT_BATCH_SIZE" Default="5" Mode="" Description="Paragraphs translated per LLM call. Lower it (e.g. 3) if a slow/contended local model times out." Type="Variable" Display="always" Required="false" Mask="false">5</Config>
  <Config Name="Max Upstream Inflight" Target="BT_MAX_UPSTREAM_INFLIGHT" Default="2" Mode="" Description="Process-wide cap on simultaneous LLM calls. Values must be greater than zero; 2 is safe for a single local GPU." Type="Variable" Display="always" Required="false" Mask="false">2</Config>
  <Config Name="Singleflight Active Entries" Target="BT_SINGLEFLIGHT_MAX_ENTRIES" Default="1024" Mode="" Description="Maximum distinct active translations tracked for duplicate-work coalescing. Must be greater than zero." Type="Variable" Display="advanced" Required="false" Mask="false">1024</Config>
  <Config Name="Max Provider Response Bytes" Target="BT_MAX_UPSTREAM_RESPONSE_BYTES" Default="1048576" Mode="" Description="Maximum decompressed JSON bytes accepted from one LLM response. Must be greater than zero." Type="Variable" Display="advanced" Required="false" Mask="false">1048576</Config>
  <Config Name="Max Concurrent" Target="BT_MAX_CONCURRENT" Default="2" Mode="" Description="Simultaneous translation requests. For a slow local model, 1-2 is more stable than 3." Type="Variable" Display="always" Required="false" Mask="false">2</Config>
  <Config Name="Request Timeout (s)" Target="BT_TIMEOUT" Default="60" Mode="" Description="Seconds before a single translation request is abandoned." Type="Variable" Display="advanced" Required="false" Mask="false">60</Config>
  <Config Name="Context Window" Target="BT_CONTEXT_WINDOW" Default="0" Mode="" Description="Previous/next paragraphs given to the LLM as context (0 = off, faster; 1-2 = better literary coherence, more tokens)." Type="Variable" Display="advanced" Required="false" Mask="false">0</Config>
  <Config Name="Cache TTL (days)" Target="BT_CACHE_TTL_DAYS" Default="90" Mode="" Description="Mandatory maximum retention for translated cache rows. Must be greater than zero." Type="Variable" Display="advanced" Required="false" Mask="false">90</Config>
  <Config Name="Cache Max Entries" Target="BT_CACHE_MAX_ENTRIES" Default="100000" Mode="" Description="Mandatory maximum number of scoped cache rows. Must be greater than zero." Type="Variable" Display="advanced" Required="false" Mask="false">100000</Config>
  <Config Name="Max Tokens (single)" Target="BT_MAX_TOKENS" Default="4096" Mode="" Description="Hard ceiling on generated tokens for a single-paragraph request. Lower it (e.g. 640) to fail fast on a slow/contended model." Type="Variable" Display="advanced" Required="false" Mask="false">4096</Config>
  <Config Name="Max Tokens (batch)" Target="BT_BATCH_MAX_TOKENS" Default="8192" Mode="" Description="Hard ceiling on generated tokens for a batched request. Lower it (e.g. 1200) to fail fast under contention." Type="Variable" Display="advanced" Required="false" Mask="false">8192</Config>
</Container>
