# book-translator — proxy-injection mode.
# Rendered only after proxy/render_config.py validates every ${...} value.
# nginx's own $variables remain runtime variables.
#
# Browser ──► :${BT_PROXY_PORT} (this nginx) ──► ${CWA_UPSTREAM} (stock CWA)
#   /bt-api/*     → the local translation API (same-origin: no CORS needed)
#   /bt-static/*  → overlay JS/CSS served from this container
#   everything    → proxied to CWA; HTML gets ONE <script> tag injected

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen ${BT_PROXY_PORT};
    # Any redirect generated by nginx itself stays relative, so an arbitrary
    # inbound Host header cannot become an absolute Location authority.
    absolute_redirect off;

    # CWA handles book uploads, but an unlimited buffered body is a disk DoS.
    # Operators can raise this finite validated value for unusually large books.
    client_max_body_size ${BT_CWA_MAX_BODY_SIZE};

    # We strip upstream Accept-Encoding so sub_filter can see the HTML;
    # re-compress on the way out so clients still get gzip.
    gzip on;
    gzip_types text/css application/javascript application/json;

    location /bt-api/ {
        # The API's own WSGI cap is 2 MB (BT_MAX_CONTENT_LENGTH); 3 MB here
        # lets Flask return its structured JSON 413 while nginx still stops
        # grossly oversized bodies before buffering them to the backend.
        # (The catch-all location uses the separate finite CWA upload cap.)
        client_max_body_size 3m;
        proxy_pass ${BT_API_UPSTREAM}/;
        proxy_ssl_server_name on;
        proxy_set_header Host ${BT_PUBLIC_HOST};
        # Forward the browser's HttpOnly CWA session to the API. The API sends
        # only configured cookie names to CWA's authenticated JSON probe.
        proxy_set_header Cookie $http_cookie;
        # This injection proxy is not an identity authority. Always discard
        # client-supplied forwarded identity; forwarded auth deployments must
        # route /bt-api through their allowlisted identity-aware proxy instead.
        proxy_set_header X-BT-Subject "";
        proxy_set_header X-BT-Roles "";
        proxy_set_header X-authentik-uid "";
        proxy_set_header X-authentik-groups "";
        # Never extend client-supplied forwarding chains. The API trusts this
        # proxy as an immediate peer and receives only the address nginx saw.
        proxy_set_header Forwarded "";
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Host ${BT_PUBLIC_HOST};
        proxy_set_header X-Forwarded-Port "";
        proxy_set_header X-Forwarded-Proto ${BT_PUBLIC_SCHEME};
        proxy_connect_timeout 2s;
        # Translation calls can legitimately take a while on slow local LLMs.
        proxy_read_timeout 180s;
    }

    location = /bt-config.json {
        alias /tmp/nginx/browser-config.json;
        default_type application/json;
        add_header Cache-Control "no-store" always;
        add_header Pragma "no-cache" always;
    }

    location /bt-static/ {
        alias /app/static/;
        add_header Cache-Control "public, max-age=300";
    }

    location / {
        proxy_pass ${CWA_UPSTREAM};
        proxy_http_version 1.1;
        proxy_ssl_server_name on;
        proxy_set_header Host ${BT_PUBLIC_HOST};
        proxy_set_header Forwarded "";
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Host ${BT_PUBLIC_HOST};
        proxy_set_header X-Forwarded-Port "";
        proxy_set_header X-Forwarded-Proto ${BT_PUBLIC_SCHEME};
        # CWA can treat a configurable header as a complete login assertion.
        # This proxy is not that authority and must not forward a client value.
        proxy_set_header ${BT_CWA_IDENTITY_HEADER} "";
        proxy_set_header X-authentik-uid "";
        proxy_set_header X-authentik-groups "";
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_connect_timeout 2s;
        proxy_read_timeout 300s;

        # The whole plugin injection: one tag before </head> on HTML responses.
        # loader.js self-guards to /read/ pages, so injecting site-wide is safe
        # and keeps this config free of assumptions about CWA's routes.
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<script src="/bt-static/loader.js?v=${BT_UI_VERSION}"></script></head>';
        sub_filter_once on;
    }
}
