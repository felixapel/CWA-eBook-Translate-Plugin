# CWA Translate v2.2.0 source-only installer configuration.
# Copy this file outside the checkout, edit it, then run:
#   ./btctl plan --env /absolute/path/install.env
# Never commit the edited file: it can contain LLM_API_KEY.

# unraid | compose-existing (CWA itself always remains external)
BT_INSTALL_PROFILE=unraid
BT_INSTALL_NAME=cwa-translate

# published exposes only the injection proxy on BT_PROXY_PORT.
# docker-edge publishes no host port and requires BT_EDGE_NETWORK.
BT_INGRESS_MODE=published
BT_PROXY_PORT=8385
BT_EDGE_NETWORK=

# Safe default: the API validates the browser's native CWA session.
# Advanced SSO uses authentik-forwarded; see docs/AUTHENTIK.md.
BT_AUTH_PROFILE=cwa-session
BT_PUBLIC_ORIGIN=https://books.example.com

# Existing CWA identity and connectivity. CWA 4.x is Tier 1; exactly 3.1.4 is
# legacy migration compatibility. Other versions fail closed.
CWA_UPSTREAM=http://calibre-web-automated:8083
BT_CWA_CONTAINER=calibre-web-automated
BT_CWA_NETWORK=cwa_default
BT_CWA_VERSION=4.0.6

# Keep mutable state, translation data, and backups outside this Git checkout.
BT_STATE_DIR=/mnt/user/appdata/cwa-translate/state
BT_DATA_DIR=/mnt/user/appdata/cwa-translate/data
BT_BACKUP_DIR=/mnt/user/backups/cwa-translate
BT_UNRAID_TEMPLATE_DIR=/boot/config/plugins/dockerMan/templates-user

# Local OpenAI-compatible backend (vLLM, LM Studio, Ollama, llama.cpp).
LLM_PROVIDER=local
LLM_MODEL=gemma4-12b
BT_LOCAL_URL=http://192.168.0.122:2819/v1/chat/completions
LLM_API_KEY=

# Authentik-forwarded only. Leave empty for cwa-session.
BT_IDENTITY_PROXY_IP=
BT_AUTHENTIK_VERSION=
BT_REVERSE_PROXY=
